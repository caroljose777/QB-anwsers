    <title>College Homepage</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- 1. Navigation Bar -->
    <nav class="navbar">
        <div class="logo">City College</div>
        <ul class="nav-links">
            <li><a href="#">Home</a></li>
